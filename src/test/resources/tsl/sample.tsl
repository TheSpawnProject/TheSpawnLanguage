#! COOLDOWN 1000
#! COOLDOWN 3000
#! COOLDOWN 2000 # <-- Dis will override the ones above

$name = diamond # Inline comment!

$someAction = PRINT %Hello World!% # Inline comment!

$someAction # Inline comment!
 ON Alert Event

PRINT %Hey dude! This message is evaluated @ ${_currentUnix()}%
 ON Alert Event
 WITH time = 12345

@suppressNotifications
PRINT ${_maximumOf(10,20) + Math.random()}
 ON Alert Event

# Eyyy, a comment here!

#*
 Eyyyy, yet another comment here!
*#

@notificationVolume(2f)
@notificationPitch(2f)
EITHER
 DROP $name
 OR
 (EITHER DROP apple OR DROP string)
 OR
 (EITHER DROP apple OR (EITHER DROP string OR diamond))
 ON Alert Event

PRINT
%Time to ditch indentations, ${"aye"}!%
ON Alert Event