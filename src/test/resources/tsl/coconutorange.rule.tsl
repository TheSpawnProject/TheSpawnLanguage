#* tsl-ignore *#

# TODO: Add imports and aliases on Rulesets
# TODO: Add IMPORT tag definition
#! IMPORT COU FROM coconutplugin
#! IMPORT Redux FROM redux
#! IMPORT Web FROM web

#! COU.GLOBAL_PREFIX %[COCO]%

@vanillaDecorator(1)
FOR 5 TIMES
 PRINT ${Math.random()}
 ON Manual Trigger

# TODO: Make decorators evaluate on perform
@COU.prefix(${Date.now()})
FOR 5 TIMES
 COU.PRINT ${COU.randomNumber()} # TODO: Make namespaces parse-able
 ON Coconut Feast Event FROM COU # TODO: Parse FROM keyword after ON
 WITH coconutsEaten = 10

@Web.setURL(${"http://mywebsite.com/" + block})
Redux.DISPATCH %{action:"My Action", arguments: {foo:1, bar:2, baz:3}}%
 ON Minecraft Block Break FROM COU
 WITH block IS %minecraft:bed%

