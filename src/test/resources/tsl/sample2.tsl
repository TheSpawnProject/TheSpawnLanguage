%String with spaces%
%String with anything%
%String with \% escapes%
%String with ${expression here with spaces}%

${10 % 2}
${{{X}} + 5}

%String with ${10 % 2}%

$call(A, B, C)
$call(${1%1}, ${variable})
$call()
$call
$call({{X}})
*#