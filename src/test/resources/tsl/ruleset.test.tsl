#! COOLDOWN 30
#! COOLDOWN 100

$printPrefix(prefix, timestamp)
 = %[{{prefix}}] [{{timestamp}}]%

$printAction(text)
 = PRINT $printPrefix(TSL, ${Date.now().toString()}) {{text}}

@suppressNotifications
$printAction(%${"foo"} bar baz%)
 ON Dummy Event
 WITH time = 5

$printAction(%${"foo"} bar baz%)
 ON Dummy Event
 WITH time = 5