#! IMPORT EP FROM exampleplugin

#**
 * This capture holds multiplication of given numbers
 * @param a First number to be used
 * @param b Second number to be used
*#
$multiplyNumbers(num1, num2)
  = ${{{num1}} * {{num2}}}

$myAction =
FOR 5 TIMES
  IF true THEN
    EP.PRINT %Hey! ${event}%
  ELSE
    NOTHING

#* FOR 10 TIMES
  IF true THEN
    WAIT $multiplyNumbers(10, 20) minutes
  ELSE
    WAIT 10 seconds
ON Manual Trigger
WITH ${event.debug_data.meta == 1} *#

$myAction
DISPLAYING 1
ON Manual Trigger

# PRINT ${runScript(new String(__context()))}
#  ON Dummy Event
