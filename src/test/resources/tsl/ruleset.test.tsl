#! COOLDOWN 30
#! COOLDOWN 100

$fizzBuzz
= IF ${++i % 16 == 0} THEN
   PRINT Fizzbuzz
  ELSEIF ${i % 3 == 0} THEN
   PRINT Fizz
  ELSEIF ${i % 5 == 0} THEN
   PRINT Buzz DISPLAYING %elseif%
  ELSE
   PRINT ${i} DISPLAYING %else%

FOR ${i=0; 15} TIMES $fizzBuzz
ON Dummy Event
WITH time = 5

PRINT ${i} ${time}
ON Dummy Event
WITH time = 5



# ----------------------------------------------



#*

$printPrefix(prefix, timestamp)
 = %[{{prefix}}] [{{timestamp}}]%

$printAction(text)
 = PRINT $printPrefix(TSL, ${Date.now().toString()}) {{text}}

@suppressNotifications
$printAction(%${"foo"} bar baz%)
 ON Dummy Event
 WITH time = 5

$ifStatement(a,b)
 = IF {{a}} THEN
    $printAction(%${"foo"} bar baz%)
   ELSEIF {{b}} THEN
    PRINT %Elif!%
   ELSE
    PRINT Oppsie

$ifStatement(true, true)
ON Dummy Event
WITH time = 5

$ifStatement(false, true)
ON Dummy Event
WITH time = 5

$ifStatement(false, false)
ON Dummy Event
WITH time = 5

PRINT ${tslContext.getEventArguments()}
ON Dummy Event
WITH time = 5

IF ${1===1} THEN
 $printAction(%${"foo"} bar baz%)
ELSEIF true THEN
 PRINT %Elif!%
ELSE
 PRINT Oppsie
ON Dummy Event
WITH time = 5

IF false THEN
 $printAction(%${"foo"} bar baz%)
ELSEIF true THEN
 PRINT %Elif!%
ELSE
 PRINT Oppsie
ON Dummy Event
WITH time = 5

IF false THEN
 $printAction(%${"foo"} bar baz%)
ELSEIF false THEN
 PRINT %Elif!%
ELSE
 PRINT Oppsie
ON Dummy Event
WITH time = 5

FOR 10 TIMES
 IF ${Math.random() > 0.5} THEN
  PRINT %Yahhooo!!%
 ELSE
  PRINT %Booo...%
ON Dummy Event
WITH time = 5

